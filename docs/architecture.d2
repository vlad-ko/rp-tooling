# rp-tooling architecture — regenerate the SVG with:
#   d2 --theme 0 --dark-theme 200 --pad 20 --scale 1 docs/architecture.d2 docs/architecture.svg
#
# --scale 1 is REQUIRED: without it d2 omits width/height on the outer <svg>
# (viewBox only) and GitHub renders the file at the 300x150 <img> fallback size.

direction: down

classes: {
  external: {
    style: {
      stroke-dash: 3
      fill: "#F7F7F7"
      font-color: "#444444"
      font-size: 18
    }
  }
  oneshot: {
    style: {
      stroke-dash: 3
      font-size: 15
      opacity: 0.75
    }
  }
  topic: {
    shape: queue
    style.font-size: 18
  }
  step: {
    style.font-size: 18
  }
  wire: {
    style: {
      stroke-dash: 3
      opacity: 0.6
      font-size: 14
    }
  }
}

wikimedia: "Wikimedia recent-changes\nSSE firehose · ~50 ev/s" {
  class: external
  shape: cloud
  near: top-left
}

compose: "docker compose up — zero manual steps" {
  grid-columns: 1
  grid-gap: 70
  style.font-size: 22

  connect: "Redpanda Connect  ·  plumbing only" {
    grid-rows: 1
    grid-gap: 40
    style.font-size: 20
    framing: "SSE framing\nkeep data: JSON,\ndrop heartbeats" {class: step}
    filter: "filter + project\nhuman en-wiki edits,\n|Δ| ≥ 25 bytes" {class: step}
    framing -> filter
  }

  redpanda: "Redpanda  ·  dev-container" {
    grid-rows: 1
    grid-gap: 40
    style.font-size: 20
    topic-init: "topic-init\ncreate topics, exit" {class: oneshot}
    filtered: "wiki.edits\n.filtered" {class: topic}
    classified: "wiki.edits\n.classified" {class: topic}
    deadletter: "wiki.edits\n.deadletter" {
      class: topic
      style.stroke-dash: 3
    }
  }

  service: "reasoning service  ·  TypeScript" {
    grid-rows: 2
    grid-gap: 40
    style.font-size: 20
    gate: "1 · heuristic gate\nno LLM: bot / tiny → trivia" {class: step}
    classify: "2 · classify\npass llm-1" {class: step}
    parse: "3 · parse + repair\nmax 1 retry, else unclear" {class: step}
    branch: "4 · confidence\n< 0.6 ?" {class: step}
    enrich: "5 · enrich · llm-2\nreal diff, reclassify once" {class: step}

    gate -> classify
    classify -> parse
    parse -> branch
    branch -> enrich: "yes" {style.font-size: 15}
  }

  deps: "" {
    grid-rows: 1
    grid-gap: 80
    style.stroke-width: 0
    style.fill: transparent
    ollama-init: "ollama-init\npull model, exit" {class: oneshot}
    ollama: "Ollama\nllama3.2:3b" {style.font-size: 18}
    postgres: "Postgres 16\ntable edits" {
      shape: cylinder
      style.font-size: 18
    }
    web: "web · read-only\n/api/edits · /api/stats" {style.font-size: 18}
    ollama-init -> ollama: {class: wire}
  }

  connect.filter -> redpanda.filtered: "~12 ev/min\nkey: title" {style.font-size: 15}
  connect -> redpanda.deadletter: "anomalies" {class: wire}
  redpanda.filtered -> service.gate: "group triage\nat-least-once" {style.font-size: 15}

  service.classify -> deps.ollama: "chat" {style.font-size: 15}
  service.enrich -> deps.ollama

  service -> deps.postgres: "UPSERT on rc_id" {style.font-size: 15}
  service -> redpanda.classified: "audit" {style.font-size: 15}

  deps.postgres -> deps.web: "SELECT only" {style.font-size: 15}
}

browser: "you\nlocalhost:8080" {
  shape: person
  style.font-size: 18
  near: bottom-center
}

mediawiki: "MediaWiki\ncompare API" {
  class: external
  shape: cloud
  near: bottom-right
}

wikimedia -> compose.connect.framing: "SSE · UA required" {style.font-size: 15}
compose.service.enrich -> mediawiki
compose.deps.web -> browser
