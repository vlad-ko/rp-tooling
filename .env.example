# rp-tooling — configuration knobs.
# Copy to .env to override; compose works with NO .env file (every variable
# below defaults inside docker-compose.yml to the value shown here).

# Ollama model pulled by ollama-init and used by the reasoning service.
OLLAMA_MODEL=llama3.2:3b

# Postgres credentials/database (schema.sql is applied to POSTGRES_DB on
# first boot via the initdb mount).
POSTGRES_USER=rp
POSTGRES_PASSWORD=rp
POSTGRES_DB=wiki

# Host port mappings (containers talk to each other on the compose network —
# redpanda:9092, postgres:5432, ollama:11434 — these only affect host access).
# Values must stay bare: older Compose/dotenv parsers treat inline comments
# as part of the value.

# Kafka external listener, e.g. rpk -X brokers=localhost:19092
REDPANDA_KAFKA_PORT=19092

# psql -h localhost -p 5432
POSTGRES_PORT=5432

# curl localhost:11434/api/tags
OLLAMA_PORT=11434
